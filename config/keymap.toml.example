# duet 키맵 설정 예시
# <config_dir>/duet/keymap.toml 로 복사해서 사용.
#
# 형식: [bindings] 테이블에 "키" = "command_id".
# 여기에 적은 키가 그 command 의 기본키를 덮어쓴다 (없는 키는 기본키 유지).
# 더 쉬운 방법: 설정(Ctrl+,) → Keymap 에서 직접 Edit / Restore defaults.
#
# 키 표기 (lib/keyEvent.ts 기준, 수정자 순서 Ctrl→Alt→Shift):
#   일반 키: "J", "Enter", "Tab", "Esc", "Delete", "F2"
#   조합:    "Ctrl+C", "Ctrl+Shift+F", "Alt+Left"
#   macOS Cmd 는 "Ctrl" 로 표기 (cross-platform 통일).
#
# command_id 전체 목록은 설정 → Keymap 에서 확인 (각 행의 command).

[bindings]
# 파일 작업 (TC 표준)
"F5"           = "file.copy"
"F6"           = "file.move"
"F2"           = "file.rename"
"F7"           = "file.newFolder"
"Delete"       = "file.delete"
"Shift+Delete" = "file.deletePerm"
"Ctrl+Shift+C" = "file.copyPath"
"Ctrl+Alt+C"   = "file.copyName"
"Ctrl+Z"       = "edit.undo"

# 네비게이션 / 뷰
"Alt+Left"     = "nav.back"
"Alt+Right"    = "nav.forward"
"Ctrl+R"       = "view.refresh"
"Ctrl+H"       = "view.toggleHidden"
"Ctrl+B"       = "view.toggleSidebar"

# 탭 / 검색 / 설정
"Ctrl+T"       = "tab.new"
"Ctrl+W"       = "tab.close"
"Ctrl+F"       = "filter.focus"
"Ctrl+Shift+F" = "search.global"
"Ctrl+P"       = "palette.open"
"Ctrl+,"       = "settings.open"
